  "placementPolicy": {
    "type": "smartObjectMaskedExact",
    "bounds": "selection",
    "createLayerGroup": true,
    "createSmartObject": true,
    "maskSource": "finalSoftMask",
    "preserveOriginalSelectionMask": true,
    "featherPixels": 2,
    "opacity": 100,
    "blendMode": "normal"
  },

  "modelManifest": {
