{
  "1": {
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load SDXL Checkpoint" }
  },
  "10": {
    "inputs": {
      "image": "SOURCE_PLACEHOLDER"
    },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Source Image" }
  },
  "11": {
    "inputs": {
      "image": "MASK_PLACEHOLDER"
    },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Mask Image" }
  },
  "12": {
    "inputs": {
      "pixels": ["10", 0],
      "mask": ["11", 1],
      "vae": ["1", 2],
      "grow_mask_by": 16
    },
    "class_type": "VAEEncodeForInpaint",
    "_meta": { "title": "VAE Encode For Inpaint" }
  },
  "6": {
    "inputs": {
      "text": "PROMPT_PLACEHOLDER",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" }
  },
  "7": {
    "inputs": {
      "text": "NEGATIVE_PLACEHOLDER",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" }
  },
  "3": {
    "inputs": {
      "seed": 0,
      "steps": 28,
      "cfg": 6.5,
      "sampler_name": "euler",
      "scheduler": "karras",
      "denoise": 0.85,
      "model": ["1", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["12", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler" }
  },
  "8": {
    "inputs": {
      "samples": ["3", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "9": {
    "inputs": {
      "images": ["8", 0],
      "filename_prefix": "po-remove-pro"
    },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Output" }
  }
}
