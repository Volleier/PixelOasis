{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Job Creation Request",
  "type": "object",
  "required": ["schemaVersion", "capabilityId", "source"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "2.0"
    },
    "capabilityId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "correlationId": {
      "type": "string",
      "maxLength": 256
    },
    "idempotencyKey": {
      "type": "string",
      "maxLength": 512
    },
    "source": {
      "type": "object",
      "required": ["assetId", "scope", "bounds"],
      "properties": {
        "assetId": { "type": "string" },
        "scope": { "type": "string", "enum": ["document", "selection", "subject"] },
        "document": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 },
            "colorMode": { "type": "string" },
            "bitDepth": { "type": "integer", "minimum": 1, "maximum": 32 }
          }
        },
        "bounds": {
          "type": "object",
          "required": ["left", "top", "width", "height"],
          "properties": {
            "left": { "type": "number", "minimum": 0 },
            "top": { "type": "number", "minimum": 0 },
            "width": { "type": "number", "minimum": 1 },
            "height": { "type": "number", "minimum": 1 }
          }
        }
      }
    },
    "inputs": {
      "type": "object",
      "properties": {
        "editMaskAssetId": { "type": ["string", "null"] },
        "subjectMaskAssetId": { "type": ["string", "null"] },
        "referenceAssetIds": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 5
        },
        "points": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          },
          "maxItems": 10
        }
      }
    },
    "parameters": {
      "type": "object"
    },
    "options": {
      "type": "object",
      "properties": {
        "profile": { "type": "string", "enum": ["quality_16gb", "balanced_16gb", "safe_low_vram"] },
        "preview": { "type": "boolean" }
      }
    },
    "clientCapabilities": {
      "type": "object",
      "properties": {
        "multiArtifact": { "type": "boolean" },
        "smartObject": { "type": "boolean" },
        "layerMask": { "type": "boolean" }
      }
    }
  }
}
