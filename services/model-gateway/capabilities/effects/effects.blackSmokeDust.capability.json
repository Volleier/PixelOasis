{
  "schemaVersion": "2.0",
  "id": "effects.blackSmokeDust",
  "title": { "zh-CN": "黑色烟尘" },
  "description": { "zh-CN": "分形噪声烟体与粒子效果，支持遮挡合成" },
  "section": "sceneEffects",
  "input": {
    "source": "document",
    "mask": "optional",
    "points": "optional",
    "subjectMask": "optional"
  },
  "parameterSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "density": { "type": "number", "minimum": 0.05, "maximum": 1, "default": 0.5, "title": "浓度", "description": "烟体不透明度与覆盖面积" },
      "direction": { "type": "string", "enum": ["upRight", "upLeft", "right", "left", "up", "auto"], "enumLabels": ["右上", "左上", "右", "左", "上", "自动"], "default": "upRight", "title": "方向", "description": "主气流方向" },
      "spread": { "type": "number", "minimum": 0.1, "maximum": 1, "default": 0.45, "title": "扩散", "description": "烟团扩散角度与面积" },
      "turbulence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.55, "title": "湍流", "description": "噪声卷曲程度" },
      "particleAmount": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.35, "title": "粉尘数量", "description": "粉尘数量与亮度" },
      "occlusion": { "type": "string", "enum": ["auto", "back", "front"], "enumLabels": ["自动", "后景", "前景"], "default": "auto", "title": "遮挡", "description": "与主体的前后遮挡关系" },
      "semanticRefine": { "type": "boolean", "default": false, "title": "语义精修", "description": "局部 Qwen 融合精修（需下载模型）" },
      "seed": { "type": "integer", "minimum": 0, "maximum": 4294967295, "title": "随机种子", "description": "便于重试与复现" }
    }
  },
  "outputSchema": {
    "artifacts": [
      { "role": "smoke", "layerName": "黑色烟雾", "blendMode": "normal", "opacity": 100 },
      { "role": "dust", "layerName": "烟尘颗粒", "blendMode": "normal", "opacity": 100 },
      { "role": "compositePreview", "layerName": "黑色烟尘预览", "blendMode": "normal", "opacity": 100, "previewOnly": true }
    ]
  },
  "pipeline": "black-smoke-v1",
  "variants": [
    {
      "id": "quality_16gb",
      "profile": "quality_16gb",
      "workflowId": "smoke-dust-quality",
      "minVramGb": 14,
      "priority": 100,
      "enabled": true,
      "requiredNodes": ["PO_FractalSmokeRGBA", "PO_DustParticlesRGBA", "PO_DepthSplitRGBA", "ImageCompositeMasked"],
      "requiredModels": [{ "name": "depth_anything_v2_vits.pth", "path": "depth_anything/depth_anything_v2_vits.pth" }],
      "optionalNodes": ["TextEncodeQwenImageEdit"],
      "optionalModels": [{ "name": "qwen-image-edit", "path": "qwen/qwen-image-edit-*.safetensors" }]
    }
  ],
  "policy": { "sensitive": false },
  "enabled": true,
  "ui": { "order": 10, "requiresConfirm": true, "icon": "effects" }
}
