{
  "schemaVersion": "2.0",
  "id": "effects.blackSmokeDust",
  "title": { "zh-CN": "黑色烟尘" },
  "description": { "zh-CN": "生成大体积影视级黑烟、沙尘和碎屑，并输出一张原尺寸成品图" },
  "section": "sceneEffects",
  "input": {
    "source": "document",
    "subjectMask": "optional",
    "points": "optional"
  },
  "parameterSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "density": { "type": "number", "minimum": 0.4, "maximum": 2.0, "default": 1.35, "title": "烟尘强度" },
      "direction": { "type": "string", "enum": ["upRight", "upLeft", "right", "left", "up", "auto"], "default": "upRight", "title": "方向" },
      "spread": { "type": "number", "minimum": 0.65, "maximum": 1.5, "default": 1.05, "title": "覆盖范围" },
      "particleAmount": { "type": "number", "minimum": 0.4, "maximum": 1.0, "default": 0.72, "title": "沙尘粒子" },
      "anchorX": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.58, "title": "锚点 X" },
      "anchorY": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.62, "title": "锚点 Y" },
      "seed": { "type": "integer", "minimum": 0, "maximum": 4294967295, "title": "随机种子" }
    }
  },
  "outputSchema": {
    "artifacts": [
      { "role": "result", "layerName": "黑色烟尘成品", "blendMode": "normal", "opacity": 100, "previewOnly": false }
    ]
  },
  "pipeline": "black-smoke-v1",
  "variants": [
    {
      "id": "quality_16gb",
      "profile": "quality_16gb",
      "workflowId": "smoke-dust-quality",
      "minVramGb": 14,
      "priority": 100,
      "enabled": true,
      "requiredNodes": [
        "PO_DepthEstimate",
        "PO_SubjectMaskResolve",
        "PO_VFXPromptBuilder",
        "PO_VFXPlateComposite"
      ],
      "requiredModels": [
        { "name": "depth_anything_v2_vitl_fp16.safetensors", "path": "depthanything/depth_anything_v2_vitl_fp16.safetensors", "minSizeBytes": 500000000 },
        { "name": "z_image_turbo_bf16.safetensors", "path": "unet/z_image_turbo_bf16.safetensors", "minSizeBytes": 10000000000 },
        { "name": "qwen_3_4b.safetensors", "path": "text_encoders/qwen_3_4b.safetensors", "minSizeBytes": 7000000000 },
        { "name": "ae.safetensors", "path": "vae/ae.safetensors", "minSizeBytes": 300000000 }
      ],
      "recommendedModels": [
        { "name": "BiRefNet-HR", "purpose": "subject alpha" },
        { "name": "4x-UltraSharp", "purpose": "particle detail" },
        { "name": "Qwen-Image-Edit or FLUX.1 Kontext", "purpose": "integration refinement" }
      ]
    }
  ],
  "policy": { "sensitive": false },
  "enabled": true,
  "ui": { "order": 10, "requiresConfirm": true, "icon": "effects" }
}
